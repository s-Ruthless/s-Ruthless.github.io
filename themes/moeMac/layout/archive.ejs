<%
  var posts = site.posts.sort('date', -1);
  var layoutMode = theme.archive_timeline_layout || 'center';
  var wrapClass = 'timeline-' + layoutMode + '-wrap';
  if (layoutMode === 'center') wrapClass = 'timeline-center';
%>
<div class="page-container">
  <div class="page-header">
    <h2><i class="fas fa-folder-open"></i> 归档 · 共 <span class="badge badge-primary"><%= site.posts.length %></span> 篇</h2>
  </div>
  <div class="page-body archive-page <%= wrapClass %>">
    <ul class="timeline">
      <% var idx = 0; %>
      <% var prevYM = ''; %>
      <% var prevYear = ''; %>
      <% posts.each(function(post) { %>
        <%
          var y = date(post.date, 'YYYY');
          var m = date(post.date, 'MM');
          var ym = y + '-' + m;
          var side = (layoutMode === 'center') ? (idx % 2 === 0 ? 'timeline-start' : 'timeline-end') : 'timeline-start';
        %>
        <% if (y !== prevYear) { %>
          <% prevYear = y; prevYM = ''; %>
          <li class="timeline-header">
            <span class="badge badge-primary badge-lg"><%= y %></span>
          </li>
        <% } %>
        <% if (ym !== prevYM) { %>
          <% prevYM = ym; %>
          <li class="timeline-header">
            <span class="badge badge-ghost badge-sm"><%= parseInt(m) %>月</span>
          </li>
        <% } %>
        <li>
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 text-primary"><circle cx="10" cy="10" r="6"/></svg>
          </div>
          <div class="<%= side %> timeline-box card card-compact bg-base-100/50 backdrop-blur-sm shadow-sm hover:shadow-md transition-all duration-200 cursor-pointer ajax-link" data-href="<%- url_for(post.path) %>">
            <div class="card-body p-3">
              <span class="text-xs opacity-50"><%= date(post.date, 'MM-DD HH:mm') %></span>
              <a class="ajax-link font-medium text-sm" data-href="<%- url_for(post.path) %>"><%= post.title %></a>
              <% if (post.categories && post.categories.length > 0) { %>
                <div class="flex gap-1 flex-wrap mt-1">
                  <% post.categories.forEach(function(cat) { %>
                    <span class="badge badge-outline badge-xs"><i class="fas fa-folder mr-1" style="font-size:9px"></i><%= cat.name %></span>
                  <% }); %>
                </div>
              <% } %>
            </div>
          </div>
        </li>
        <% idx++; %>
      <% }); %>
      <% if (site.posts.length === 0) { %>
        <div class="text-center py-10 opacity-50">还没有文章哦～</div>
      <% } %>
    </ul>
  </div>
</div>