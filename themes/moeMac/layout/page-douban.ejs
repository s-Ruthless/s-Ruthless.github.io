<%
  // 优先读取 _data/douban.json（hexo douban 命令抓取的数据），回退到主题配置
  var jsonData = (site.data && site.data.douban) ? site.data.douban : null;
  var themeData = theme.douban || {};
  // 合并策略：JSON 中有数据的 section 用 JSON，空数组回退到主题配置
  var db = {};
  ['books', 'movies', 'music'].forEach(function(k) {
    var jsonArr = jsonData && Array.isArray(jsonData[k]) ? jsonData[k] : [];
    var themeArr = Array.isArray(themeData[k]) ? themeData[k] : [];
    db[k] = jsonArr.length > 0 ? jsonArr : themeArr;
  });
  // 过滤掉非数据字段（_meta 等）
  var sections = [
    { key: 'books',  title: '书籍', icon: 'fas fa-book-open',  empty: '还没有读过书哦～' },
    { key: 'movies', title: '电影', icon: 'fas fa-film',       empty: '还没有看过电影哦～' },
    { key: 'music',  title: '音乐', icon: 'fas fa-compact-disc', empty: '还没有听过歌单哦～' }
  ];
  function stars(rating){
    var s = Math.round((rating||0) / 2); // 10分制 -> 5星
    var html = '';
    for (var i=0;i<5;i++){ html += '<i class="fas fa-star '+(i<s?'star-on':'star-off')+'"></i>'; }
    return html;
  }
%>
<%
  var _dbIcon = 'fas fa-clapperboard';
  var _dbPath = (page.path || '').replace(/\/index\.html$/, '').replace(/^\/|\/$/g, '');
  (theme.dock || []).forEach(function(item){
    if ((item.page || '').replace(/^\/|\/$/g, '') === _dbPath) _dbIcon = item.icon;
  });
%>
<div class="page-container douban-page">
  <div class="page-body">
    <div class="page-header">
      <h2><i class="<%- _dbIcon %>"></i> <%= page.title || '豆瓣' %></h2>
      <p class="archive-subtitle">书 · 影 · 音 的碎片收藏</p>
    </div>
    <div class="page-content">
    <% sections.forEach(function(sec) { var items = db[sec.key] || []; if (items.length === 0) return; %>
    <section class="douban-section">
      <div class="douban-sec-head">
        <h3><i class="<%= sec.icon %>"></i> <%= sec.title %></h3>
        <span class="douban-count"><%= items.length %></span>
      </div>
      <div class="douban-grid">
        <% items.forEach(function(it) { %>
          <article class="douban-card">
            <div class="douban-cover">
              <% var coverSrc = it.cover_local || it.cover; %>
              <% if (coverSrc) { %>
                <img src="<%= coverSrc %>" alt="<%= it.name %>" loading="lazy" onerror="this.parentElement.innerHTML='<div class=\'douban-cover-ph\'><i class=\'<%= sec.icon %>\'></i></div>'">
              <% } else { %>
                <div class="douban-cover-ph"><i class="<%= sec.icon %>"></i></div>
              <% } %>
            </div>
            <div class="douban-info">
              <h4 class="douban-name"><%= it.name %></h4>
              <% if (it.info) { %><p class="douban-meta"><%= it.info %></p><% } %>
              <div class="douban-rating">
                <span class="douban-stars"><%- stars(it.rating) %></span>
              </div>
              <% if (it.note) { %><p class="douban-note"><%= it.note %></p><% } %>
              <% if (it.link) { %><a class="douban-link" href="<%= it.link %>" target="_blank" rel="noopener noreferrer">详情 <i class="fas fa-arrow-right"></i></a><% } %>
            </div>
          </article>
        <% }); %>
      </div>
    </section>
    <% }); %>

    <% var hasAny = sections.some(function(sec){ return (db[sec.key]||[]).length > 0; }); %>
    <% if (!hasAny) { %>
      <div class="douban-empty">
        <i class="fas fa-box-open"></i>
        <p>还没有收藏内容</p>
        <span>方式一：在主题配置 <code>_config.yml</code> 的 <code>douban.user_id</code> 填写豆瓣 ID，运行 <code>npx hexo douban</code> 自动抓取</span><br>
        <span>方式二：在 <code>douban.books / movies / music</code> 下手动添加条目</span>
      </div>
    <% } %>

    <% if (page.content && page.content.trim()) { %>
      <div class="divider"></div>
      <div class="article-content"><%- page.content %></div>
    <% } %>
    </div>
  </div>
</div>
