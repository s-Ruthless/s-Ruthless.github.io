<div class="page-container">
  <div class="page-body">
    <div class="page-header">
      <h2><i class="<%- dock_icon() || 'fas fa-link' %>"></i> <%= page.title || '友链' %></h2>
    </div>
    <div class="page-content">
    <% var friends = theme.friends || []; %>
    <% if (friends.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <% friends.forEach(function(f) { %>
          <a href="<%= f.url %>" target="_blank" rel="noopener" class="friend-card card card-side backdrop-blur-sm shadow-sm hover:shadow-lg hover:border-primary/30 border border-transparent transition-all duration-200">
            <figure class="px-4 py-4">
              <img src="<%= f.avatar %>" alt="<%= f.name %>" class="w-12 h-12 rounded-full object-cover" onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(f.name) %>&background=random'">
            </figure>
            <div class="card-body p-4 justify-center">
              <h3 class="card-title text-sm"><%= f.name %></h3>
              <p class="text-xs opacity-50"><%= f.description || '' %></p>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
    <div class="article-content"><%- page.content %></div>
    <%- partial('_partial/comments') %>
    </div>
  </div>
</div>