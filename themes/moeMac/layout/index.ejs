<% var windows = theme.home_windows || ['posts','categories','tags','music','data']; %>
<% var winClassMap = { posts:'window-article', categories:'window-categories', tags:'window-tag', music:'window-music', data:'window-data', info:'window-info' }; %>
<% var winTitleMap = { posts:'最新文章', categories:'分类', tags:'标签云', music:'歌单', data:'站点数据', info:'网站信息' }; %>
<% var winIconMap = { posts:'fas fa-newspaper', categories:'fas fa-folder', tags:'fas fa-tags', music:'fas fa-music', data:'fas fa-chart-bar', info:'fas fa-circle-info' }; %>
<% var useImageAvatar = theme.avatar_type === 'image' && theme.avatar_url; %>

<div class="app-window window-main drag-win" id="win-hero" style="left:50%;top:50%;">
  <div class="win-traffic">
    <button class="win-traffic-btn win-btn-close" data-tip="关闭" aria-label="关闭"><svg viewBox="0 0 12 12" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round"><path d="M3 3L9 9M9 3L3 9"/></svg></button>
    <button class="win-traffic-btn win-btn-minimize" data-tip="最小化" aria-label="最小化"><svg viewBox="0 0 12 12" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round"><path d="M3 6H9"/></svg></button>
    <button class="win-traffic-btn win-btn-pin" data-tip="置顶" aria-label="置顶"><svg viewBox="0 0 12 12" fill="#fff"><path d="M6 1L4 3v3L2.5 7.5V9h3V11h1V9h3V7.5L8 6V3L6 1z"/></svg></button>
  </div>
  <div class="win-head drag-bar">
    <div class="win-name"><i class="fas fa-house win-head-icon"></i>我的主页</div>
  </div>
  <div class="win-body">
    <div class="hero-ava" id="hero-avatar">
      <% if (useImageAvatar) { %>
        <img src="<%= theme.avatar_url %>" alt="avatar" class="hero-ava-img" onerror="this.parentElement.innerHTML='<%= theme.avatar_text || '我' %>'">
      <% } else { %>
        <%= theme.avatar_text || '我' %>
      <% } %>
    </div>
    <div class="hero-text">
      <h2><%= theme.blog_name || config.title %></h2>
      <p><%- theme.blog_description || config.description %></p>
      <% if (theme.social && theme.social.length) { %>
      <div class="hero-social">
        <% var svgIcons = {
          github: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>',
          email: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>',
          qq: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21.395 15.035a39.548 39.548 0 0 0-.803-2.264l-1.079-2.695c.001-.032.014-.562.014-.836C19.527 4.632 17.123 1 12 1S4.473 4.632 4.473 9.24c0 .274.013.804.014.836l-1.08 2.695a39.547 39.547 0 0 0-.802 2.264c-1.021 3.282-.69 4.643-.438 4.673.54.065 2.103-2.476 2.103-2.476 0 1.469.756 3.387 2.394 4.771-.612.188-1.363.479-1.845.835-.434.32-.379.646-.301.778.343.578 5.883.369 7.482.189 1.6.18 7.14.389 7.483-.189.077-.132.132-.458-.301-.778-.482-.356-1.233-.647-1.846-.836 1.637-1.384 2.393-3.302 2.393-4.771 0 0 1.563 2.541 2.103 2.476.251-.03.582-1.391-.439-4.673z"/></svg>',
          wechat: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.648-6.726 1.425-1.683 3.49-2.681 5.375-2.681.116 0 .228.018.343.025C15.632 4.252 12.471 2.188 8.691 2.188zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.86c-1.797 0-3.891.897-5.207 2.498-1.349 1.633-2.099 3.733-1.386 6.024.012.035.023.07.023.107 0 .163-.13.295-.29.295a.326.326 0 0 1-.167-.054l-1.903-1.114a.864.864 0 0 0-.717-.098 10.16 10.16 0 0 0-2.837-.403c-3.572 0-6.522 2.516-6.522 6.096"/></svg>',
          twitter: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
          bilibili: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.77-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.387-.947.258-.257.574-.386.946-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/></svg>',
          zhihu: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M5.721 0C2.251 0 0 2.25 0 5.719V18.28C0 21.751 2.252 24 5.721 24h12.56C21.751 24 24 21.75 24 18.281V5.72C24 2.249 21.75 0 18.281 0zm1.964 4.078c-.271.73-.5 1.434-.68 2.11h5.285c.34-.005.51.16.51.483v.527c0 .323-.17.49-.51.49h-2.244v3.76h2.014c.34-.005.51.16.51.483v.523c0 .323-.17.487-.51.483h-2.014v5.245c0 .34-.172.51-.513.51h-.96c-.342 0-.51-.17-.51-.51V7.476c.157-.828.43-1.566.817-2.215.388-.65.878-1.23 1.47-1.745h-3.93Z"/></svg>',
          link: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>'
        }; %>
        <% theme.social.forEach(function(s) { %>
          <a href="<%= s.url %>" class="hero-social-btn" title="<%= s.label || s.type %>" target="_blank" rel="noopener">
            <%- svgIcons[s.type] || svgIcons.link %>
          </a>
        <% }); %>
      </div>
      <% } %>
      <div class="hero-hitokoto">
        <% if (theme.hitokoto !== false) { %>
        <span class="hero-hitokoto-text" id="hitokoto-text" data-api="<%= theme.hitokoto_api || 'https://v1.hitokoto.cn/' %>">「加载中...」</span>
        <% } else { var sList = theme.sentences || ['生活明朗，万物可爱。']; var sRand = sList[Math.floor(Math.random() * sList.length)]; %>
        <span class="hero-hitokoto-text" id="hitokoto-text">「<%= sRand %>」</span>
        <% } %>
        <span class="hero-hitokoto-from" id="hitokoto-from"></span>
      </div>
    </div>
  </div>
</div>

<% windows.forEach(function(w) { %>
<div class="app-window <%= winClassMap[w] || 'window-article' %> drag-win" id="win-<%= w %>">
  <div class="win-traffic">
    <button class="win-traffic-btn win-btn-close" data-tip="关闭" aria-label="关闭"><svg viewBox="0 0 12 12" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round"><path d="M3 3L9 9M9 3L3 9"/></svg></button>
    <button class="win-traffic-btn win-btn-minimize" data-tip="最小化" aria-label="最小化"><svg viewBox="0 0 12 12" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round"><path d="M3 6H9"/></svg></button>
    <button class="win-traffic-btn win-btn-pin" data-tip="置顶" aria-label="置顶"><svg viewBox="0 0 12 12" fill="#fff"><path d="M6 1L4 3v3L2.5 7.5V9h3V11h1V9h3V7.5L8 6V3L6 1z"/></svg></button>
  </div>
  <div class="win-head drag-bar">
    <div class="win-name"><i class="<%= winIconMap[w] || 'fas fa-window-maximize' %> win-head-icon"></i><%= winTitleMap[w] || w %></div>
  </div>
  <div class="win-body">
    <% if (w === 'posts') { %>
      <%- partial('_partial/window-posts') %>
    <% } else if (w === 'categories') { %>
      <%- partial('_partial/window-categories') %>
    <% } else if (w === 'tags') { %>
      <%- partial('_partial/window-tags') %>
    <% } else if (w === 'music') { %>
      <div id="music-window-mount"></div>
    <% } else if (w === 'data') { %>
      <%- partial('_partial/window-data') %>
    <% } else if (w === 'info') { %>
      <%- partial('_partial/window-info') %>
    <% } %>
  </div>
</div>
<% }); %>