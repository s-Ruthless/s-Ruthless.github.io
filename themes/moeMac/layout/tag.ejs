<%
  var tagName = page.tag;
  var posts = page.posts.sort('date', -1);
%>
<div class="page-container">
  <div class="page-header">
    <h2><i class="fas fa-tag"></i> 标签 · <span class="badge badge-secondary badge-sm">#<%= tagName %></span></h2>
  </div>
  <div class="page-body">
    <div class="flex flex-col gap-3">
    <% posts.each(function(post) { %>
      <div class="card card-compact bg-base-100/40 backdrop-blur-sm shadow-sm hover:shadow-md hover:border-primary/30 border border-transparent transition-all duration-200 cursor-pointer ajax-link" data-href="<%- url_for(post.path) %>">
        <div class="card-body p-4 flex-row items-center gap-4">
          <span class="badge badge-ghost badge-sm shrink-0"><%= date(post.date, 'MM-DD') %></span>
          <a class="ajax-link text-sm font-medium" data-href="<%- url_for(post.path) %>"><%= post.title %></a>
        </div>
      </div>
    <% }); %>
    </div>
    <% if (posts.length === 0) { %>
      <div class="text-center py-10 opacity-50">该标签下还没有文章～</div>
    <% } %>
    <% if (typeof page.total !== 'undefined' && page.total > 1) { %>
      <div class="join flex justify-center mt-6">
        <% if (page.prev) { %>
          <a class="join-item btn btn-sm btn-ghost ajax-link" data-href="<%- url_for(page.prev_link) %>"><i class="fas fa-chevron-left"></i> 上一页</a>
        <% } %>
        <span class="join-item btn btn-sm btn-ghost no-animation"><%= page.current %> / <%= page.total %></span>
        <% if (page.next) { %>
          <a class="join-item btn btn-sm btn-ghost ajax-link" data-href="<%- url_for(page.next_link) %>">下一页 <i class="fas fa-chevron-right"></i></a>
        <% } %>
      </div>
    <% } %>
  </div>
</div>