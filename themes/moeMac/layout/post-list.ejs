<%
  var posts = page.posts ? page.posts.sort('date', -1) : site.posts.sort('date', -1).limit(config.per_page || 10);
%>

<div class="page-container">
  <div class="page-body">
    <div class="page-header">
      <h2><i class="fas fa-newspaper"></i> 文章列表</h2>
    </div>
    <div class="page-content">
      <div class="flex flex-col gap-3">
      <% posts.each(function(post) { %>
        <div class="post-list-item card card-compact backdrop-blur-sm shadow-sm hover:shadow-md hover:border-primary/30 border border-transparent transition-all duration-200 cursor-pointer ajax-link" data-href="<%- url_for(post.path) %>">
          <div class="card-body p-4">
            <h3 class="card-title text-sm ajax-link" data-href="<%- url_for(post.path) %>"><%= post.title %></h3>
            <div class="flex items-center gap-2 text-xs opacity-50">
              <i class="fas fa-calendar-days"></i>
              <span><%= date(post.date, 'YYYY-MM-DD') %></span>
              <% if (post.categories && post.categories.length > 0) { %>
                <span>·</span>
                <i class="fas fa-folder"></i>
                <% post.categories.forEach(function(cat, i) { %>
                  <a class="ajax-link hover:text-primary" data-href="<%- url_for(cat.path) %>"><%= cat.name %></a><%= i < post.categories.length - 1 ? ', ' : '' %>
                <% }); %>
              <% } %>
            </div>
            <% if (post.excerpt || post.content) { %>
              <p class="text-xs opacity-40 line-clamp-2 mt-1"><%- strip_html(post.excerpt || post.content || '').substring(0, 120) %></p>
            <% } %>
            <% if (post.tags && post.tags.length > 0) { %>
              <div class="post-list-tags flex flex-wrap gap-1.5 mt-2">
                <% post.tags.forEach(function(tag) { %>
                  <a class="post-list-tag ajax-link" data-href="<%- url_for(tag.path) %>">
                    <i class="fas fa-hashtag"></i><%= tag.name %>
                  </a>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>
      </div>

      <% if (site.posts.length === 0) { %>
        <div class="text-center py-10 opacity-50">还没有文章哦，快去写一篇吧～</div>
      <% } %>

      <% if (typeof page.total !== 'undefined' && page.total > 1) { %>
        <div class="join flex justify-center mt-6">
          <% if (page.prev) { %>
            <a class="join-item btn btn-sm btn-ghost ajax-link" data-href="<%- url_for(page.prev_link) %>"><i class="fas fa-chevron-left"></i> 上一页</a>
          <% } %>
          <span class="join-item btn btn-sm btn-ghost no-animation"><%= page.current %> / <%= page.total %></span>
          <% if (page.next) { %>
            <a class="join-item btn btn-sm btn-ghost ajax-link" data-href="<%- url_for(page.next_link) %>">下一页 <i class="fas fa-chevron-right"></i></a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
