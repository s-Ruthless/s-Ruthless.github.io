<%
  var A = (theme.cdn || '') + '/assets';
  var c = theme.comments || {};
  if (c.enable !== true) return;
  /* 评论开关：page.comment 优先；未设置时文章默认显示，自定义页面默认不显示 */
  var isPost = page.layout === 'post';
  var showComments = page.comment !== undefined ? page.comment : isPost;
  if (!showComments) return;
  var p = c.provider || 'waline';

  /* 检查当前 provider 配置是否完整 */
  var providerOk = false;
  var hintMsg = '';
  if (p === 'giscus') {
    providerOk = c.giscus && c.giscus.repo;
    if (!providerOk) hintMsg = 'Giscus 缺少 repo 配置，请在 _config.yml 的 comments.giscus.repo 填写 GitHub 仓库（owner/repo）';
  } else if (p === 'waline') {
    providerOk = c.waline && c.waline.serverURL;
    if (!providerOk) hintMsg = 'Waline 缺少 serverURL 配置，请在 _config.yml 的 comments.waline.serverURL 填写服务端地址';
  } else if (p === 'twikoo') {
    providerOk = c.twikoo && c.twikoo.envId;
    if (!providerOk) hintMsg = 'Twikoo 缺少 envId 配置，请在 _config.yml 的 comments.twikoo.envId 填写环境 ID';
  } else if (p === 'gitalk') {
    providerOk = c.gitalk && c.gitalk.clientID;
    if (!providerOk) hintMsg = 'Gitalk 缺少 clientID 配置，请在 _config.yml 的 comments.gitalk 中填写 clientID / clientSecret / repo / owner';
  } else if (p === 'cwd') {
    providerOk = c.cwd && c.cwd.apiBaseUrl;
    if (!providerOk) hintMsg = 'CWD 缺少 apiBaseUrl 配置，请在 _config.yml 的 comments.cwd.apiBaseUrl 填写 API 地址';
  } else {
    hintMsg = '未知的评论系统 provider：' + p + '，支持 giscus / waline / twikoo / gitalk / cwd';
  }
  var giscusOk = p === 'giscus' && providerOk;
%>
<div class="comments-wrap" id="comments-wrap"<% if (p === 'cwd') { %> style="border:none;box-shadow:none;background:transparent;backdrop-filter:none;-webkit-backdrop-filter:none;padding:0;"<% } %>>
  <% if (providerOk) { %>
  <div class="comments-loading" id="comments-loading"<% if (p === 'cwd') { %> style="background:transparent;border-radius:0;"<% } %>><div class="comments-spinner"></div><span>评论加载中…</span></div>
  <% } %>
  <div id="comments-mount"<% if (giscusOk) { %> class="comments-mount-giscus"<% } %>>
    <% if (giscusOk) { %>
    <script>
      /* Giscus 评论：使用内置主题，支持 _config.yml 中配置 light/dark 主题名。
         暗黑模式通过 postMessage 动态切换主题。 */
      (function(){
        var dark = document.documentElement.getAttribute('data-theme') === 'dark';
        var lightTheme = '<%= c.giscus.theme_light || "noborder_light" %>';
        var darkTheme  = '<%= c.giscus.theme_dark || "noborder_dark" %>';
        var theme = dark ? darkTheme : lightTheme;

        var s = document.createElement('script');
        s.src = 'https://giscus.app/client.js';
        s.setAttribute('data-repo', '<%= c.giscus.repo %>');
        s.setAttribute('data-repo-id', '<%= c.giscus.repoId %>');
        s.setAttribute('data-category', '<%= c.giscus.category %>');
        s.setAttribute('data-category-id', '<%= c.giscus.categoryId %>');
        s.setAttribute('data-mapping', '<%= c.giscus.mapping || 'pathname' %>');
        s.setAttribute('data-strict', '1');
        s.setAttribute('data-reactions-enabled', '<%= c.giscus.reactionsEnabled !== undefined ? c.giscus.reactionsEnabled : 0 %>');
        s.setAttribute('data-emit-metadata', '0');
        s.setAttribute('data-input-position', '<%= c.giscus.inputPosition || 'top' %>');
        s.setAttribute('data-theme', theme);
        s.setAttribute('data-lang', 'zh-CN');
        s.setAttribute('data-loading', 'eager');
        s.setAttribute('crossorigin', 'anonymous');
        s.async = true;
        s.onerror = function(){
          if(window.__commentsShowError) window.__commentsShowError('评论脚本加载失败（404），请检查网络或稍后重试');
        };
        document.getElementById('comments-mount').appendChild(s);
      })();
    </script>
    <% } %>
  </div>
</div>
<script>
  (function(){
    var loading = document.getElementById('comments-loading');
    var wrap = document.getElementById('comments-wrap');
    var mount = document.getElementById('comments-mount');
    if(!loading || !wrap) return;

    var hidden = false;
    function hideLoading(){
      if(hidden) return;
      hidden = true;
      loading.style.opacity = '0';
      loading.style.transition = 'opacity 0.4s ease';
      /* 淡入评论容器 + 高度平滑过渡 */
      if(mount){
        mount.style.opacity = '1';
        mount.style.transform = 'translateY(0)';
        /* 标记已加载，触发 CSS 淡入动画 */
        if(mount.firstElementChild) mount.firstElementChild.setAttribute('data-loaded', 'true');
      }
      /* 评论区背景高度平滑撑开动画 */
      wrap.style.transition = 'height 0.4s ease, min-height 0.4s ease';
      setTimeout(function(){
        loading.style.display = 'none';
        /* 移除过渡，避免影响后续交互 */
        wrap.style.transition = '';
      }, 400);
    }

    var p = '<%= p %>';

    /* ---- Giscus：监听 iframe load + resizeHeight 双重确认 ---- */
    if(p === 'giscus'){
      var iframeLoaded = false;
      var heightStable = false;
      var lastHeight = 0;
      var stableTimer = null;

      var iframeObserver = new MutationObserver(function(){
        var iframe = wrap.querySelector('iframe.giscus-frame');
        if(iframe && !iframeLoaded){
          iframeLoaded = true;
          iframe.addEventListener('load', function(){
            setTimeout(checkReady, 1500);
          });
          iframeObserver.disconnect();
        }
      });
      iframeObserver.observe(mount, { childList: true, subtree: true });

      function checkReady(){
        if(hidden) return;
        if(heightStable){ hideLoading(); return; }
        setTimeout(checkReady, 500);
      }

      window.addEventListener('message', function(e){
        if(e.origin !== 'https://giscus.app') return;
        var data = e.data;
        if(!data || typeof data !== 'object' || !data.giscus) return;
        if(data.giscus.resizeHeight){
          var h = data.giscus.resizeHeight;
          if(h !== lastHeight && h > 0){
            lastHeight = h;
            clearTimeout(stableTimer);
            stableTimer = setTimeout(function(){
              heightStable = true;
              if(iframeLoaded) hideLoading();
            }, 1000);
          }
        }
      });
    }

    /* ---- CWD：初始隐藏，加载检测由 CWD init 函数接管 ---- */
    if(p === 'cwd'){
      mount.style.opacity = '0';
      mount.style.transform = 'translateY(8px)';
    }

    /* ---- Gitalk / Twikoo / Waline：MutationObserver 检测常规 DOM ---- */
    if(p === 'gitalk' || p === 'twikoo' || p === 'waline'){
      /* 初始隐藏，等待渲染完成 */
      mount.style.opacity = '0';
      mount.style.transform = 'translateY(8px)';
      var mo = new MutationObserver(function(){
        var loadedEl = wrap.querySelector('.gt-container, .tk-comment, .wl-panel');
        if(loadedEl){
          loadedEl.setAttribute('data-loaded', 'true');
          hideLoading();
          mo.disconnect();
        }
      });
      mo.observe(wrap, { childList: true, subtree: true });
    }

    /* 错误提示：仅当脚本加载失败（如 404）时显示，否则一直转圈 */
    function showError(msg){
      if(hidden) return;
      hidden = true;
      loading.innerHTML = '<div style="text-align:center;color:#999;font-size:13px;line-height:1.8;">'
        + '<i class="fas fa-exclamation-circle" style="font-size:20px;margin-bottom:8px;display:block;"></i>'
        + (msg || '评论加载失败')
        + '<br><a href="javascript:location.reload()" style="color:var(--accent-color);">点击重试</a>'
        + '</div>';
    }
    window.__commentsShowError = showError;
    window.__commentsHideLoading = hideLoading;
  })();
</script>

<% if (giscusOk) { %>
<script>
  /* 暗黑模式切换同步：通过 postMessage 通知 Giscus 切换内置主题。 */
  (function(){
    var lightTheme = '<%= c.giscus.theme_light || "noborder_light" %>';
    var darkTheme  = '<%= c.giscus.theme_dark || "noborder_dark" %>';
    function syncTheme(){
      var iframe = document.querySelector('iframe.giscus-frame');
      if(!iframe) return;
      var dark = document.documentElement.getAttribute('data-theme') === 'dark';
      var theme = dark ? darkTheme : lightTheme;
      iframe.contentWindow.postMessage({
        giscus: { setConfig: { theme: theme } }
      }, 'https://giscus.app');
    }
    var observer = new MutationObserver(syncTheme);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  })();
</script>

<% } else if (p === 'waline' && c.waline && c.waline.serverURL) { %>
<link rel="stylesheet" href="<%= A %>/css/waline.css">
<script type="module">
  import('<%= A %>/js/waline.js')
    .then(function(mod){ mod.init({
      el: '#comments-mount',
      serverURL: '<%= c.waline.serverURL %>',
      dark: 'html[data-theme="dark"]',
      lang: 'zh-CN'
    }); })
    .catch(function(){ if(window.__commentsShowError) window.__commentsShowError('评论脚本加载失败（404），请检查网络或稍后重试'); });
</script>

<% } else if (p === 'twikoo' && c.twikoo && c.twikoo.envId) { %>
<script src="https://cdn.jsdelivr.net/npm/twikoo@1.6.39/dist/twikoo.all.min.js" onerror="window.__commentsShowError&&window.__commentsShowError('评论脚本加载失败（404），请检查网络或稍后重试')"></script>
<script>
  (function(){
    function init(){ twikoo.init({ envId: '<%= c.twikoo.envId %>', el: '#comments-mount' }); }
    if (window.twikoo) init();
    else {
      var _tkWait = setInterval(function(){
        if(window.twikoo){ clearInterval(_tkWait); init(); }
      }, 100);
      setTimeout(function(){ clearInterval(_tkWait); }, 15000);
    }
  })();
</script>

<% } else if (p === 'gitalk' && c.gitalk && c.gitalk.clientID) { %>
<link rel="stylesheet" href="<%= A %>/css/gitalk.css">
<script src="<%= A %>/js/gitalk.min.js" onerror="window.__commentsShowError&&window.__commentsShowError('评论脚本加载失败（404），请检查网络或稍后重试')"></script>
<script>
  (function(){
    function init(){
      var gitalk = new Gitalk({
        clientID: '<%= c.gitalk.clientID %>',
        clientSecret: '<%= c.gitalk.clientSecret %>',
        repo: '<%= c.gitalk.repo %>',
        owner: '<%= c.gitalk.owner %>',
        admin: <%= JSON.stringify(c.gitalk.admin || []) %>,
        id: location.pathname,
        distractionFreeMode: false
      });
      gitalk.render('comments-mount');
    }
    if (window.Gitalk) init();
    else {
      var _gtWait = setInterval(function(){
        if(window.Gitalk){ clearInterval(_gtWait); init(); }
      }, 100);
      setTimeout(function(){ clearInterval(_gtWait); }, 15000);
    }
  })();
</script>
<% } else if (p === 'cwd' && c.cwd && c.cwd.apiBaseUrl) { %>
<script src="<%= A %>/js/cwd.js" onerror="window.__commentsShowError&&window.__commentsShowError('评论脚本加载失败（404），请检查网络或稍后重试')"></script>
<script>
  (function(){
    var dark = document.documentElement.getAttribute('data-theme') === 'dark';
    /* 主题色 — 读取页面 :root 上的 --accent-color，回退到 _config 注入值 */
    var accentColor = '<%= theme.accent_color || "#c0504d" %>';
    function getAccent(){
      return getComputedStyle(document.documentElement).getPropertyValue('--accent-color').trim() || accentColor;
    }
    /* 向 CWD Shadow DOM 注入覆盖样式 */
    function injectCwdStyles(shadow, isDark){
      var accent = getAccent();
      var style = document.createElement('style');
      style.id = 'cwd-theme-override';
      style.textContent = ''
        + ':host{--cwd-primary:' + accent + '!important;'
        + '--cwd-primary-hover:' + accent + '!important;}'
        + '.cwd-comments-container,[data-theme=light]{--cwd-primary:' + accent + '!important;'
        + '--cwd-primary-hover:' + accent + '!important;}'
        + (isDark ? '[data-theme=dark]{--cwd-primary:' + accent + '!important;'
          + '--cwd-primary-hover:' + accent + '!important;}' : '')
        + '.cwd-comment-form{border:none!important;background:transparent!important;}'
        + '.cwd-btn-primary{background:' + accent + '!important;'
          + 'border-color:' + accent + '!important;}'
        + '.cwd-btn-primary:hover{filter:brightness(1.1);}'
        + '.cwd-comment-avatar{border-radius:50%!important;}'
        /* ====== 表单输入框：内联标签 + 美化 ====== */
        + '.cwd-form-row .cwd-form-field{position:relative!important;display:block!important}'
        + '.cwd-form-row .cwd-form-field input::placeholder{color:transparent!important}'
        + '.cwd-form-row .cwd-form-field input{'
          + 'padding-left:68px!important;'
          + 'height:42px;'
          + 'border-radius:10px!important;'
          + 'font-size:14px;'
          + 'transition:border-color .2s,box-shadow .2s;}'
        /* 内联标签文字 — 通过 :has(input[type]) 区分三个字段 */
        + '.cwd-form-row .cwd-form-field:has(input[type="text"])::before,'
        + '.cwd-form-row .cwd-form-field:has(input[type="email"])::before,'
        + '.cwd-form-row .cwd-form-field:has(input[type="url"])::before{'
          + 'position:absolute;left:12px;top:0;'
          + 'height:42px;line-height:42px;'
          + 'font-size:13px;font-weight:500;color:var(--cwd-text-secondary);'
          + 'pointer-events:none;z-index:1;white-space:nowrap;}'
        + '.cwd-form-row .cwd-form-field:has(input[type="text"])::before{content:"昵称"}'
        + '.cwd-form-row .cwd-form-field:has(input[type="email"])::before{content:"邮箱"}'
        + '.cwd-form-row .cwd-form-field:has(input[type="url"])::before{content:"网址"}'
        /* 必填项红色星号 */
        + '.cwd-form-row .cwd-form-field:has(input[type="text"])::after,'
        + '.cwd-form-row .cwd-form-field:has(input[type="email"])::after{'
          + 'content:"*";position:absolute;left:42px;top:0;'
          + 'height:42px;line-height:42px;'
          + 'color:#e53e3e;font-size:14px;pointer-events:none;z-index:1;}'
        /* 评论输入框美化 */
        + '.cwd-form-textarea{'
          + 'border-radius:10px!important;'
          + 'padding:14px 16px!important;'
          + 'min-height:120px!important;'
          + 'resize:vertical;'
          + 'line-height:1.6!important;'
          + 'font-size:14px;'
          + 'transition:border-color .2s,box-shadow .2s;}'
        /* 焦点状态使用主题色 */
        + '.cwd-form-field input:focus,.cwd-form-field textarea:focus{'
          + 'border-color:' + accent + '!important;'
          + 'box-shadow:0 0 0 3px ' + accent + '26!important;}'
        /* 表单标题 */
        + '.cwd-form-title{font-size:15px!important;font-weight:600!important}'
        + '.cwd-form-label{font-size:13px!important;font-weight:500!important}'
        /* 按钮圆角 */
        + '.cwd-btn-secondary{border-radius:8px!important}';
      var old = shadow.querySelector('#cwd-theme-override');
      if(old) old.remove();
      shadow.appendChild(style);
    }
    function init(){
      var comments = new CWDComments({
        el: '#comments-mount',
        apiBaseUrl: '<%= c.cwd.apiBaseUrl %>',
        siteId: '<%= c.cwd.siteId || "" %>',
        lang: '<%= c.cwd.lang || "auto" %>',
        theme: dark ? 'dark' : 'light'
      });
      comments.mount();
      window.__cwdInstance = comments;
      /* 渲染完成后标记加载状态 */
      var mountObserver = new MutationObserver(function(){
        var firstChild = document.getElementById('comments-mount').firstElementChild;
        if(firstChild){
          firstChild.setAttribute('data-loaded', 'true');
          mountObserver.disconnect();
        }
      });
      mountObserver.observe(document.getElementById('comments-mount'), { childList: true });
      /* 等待 Shadow DOM 创建后注入样式 + 检测评论加载完成 */
      var styleTimer = setInterval(function(){
        var host = document.getElementById('comments-mount');
        if(host && host.shadowRoot){
          injectCwdStyles(host.shadowRoot, document.documentElement.getAttribute('data-theme') === 'dark');
          clearInterval(styleTimer);
          /* 清除输入框 placeholder，避免与内联标签重复显示 */
          function clearPlaceholders(){
            var inputs = host.shadowRoot.querySelectorAll('.cwd-form-row input');
            for(var i = 0; i < inputs.length; i++){
              if(inputs[i].placeholder) inputs[i].placeholder = '';
            }
          }
          clearPlaceholders();
          /* 监听 CWD 重新渲染，持续清除 placeholder */
          var phObserver = new MutationObserver(function(){ clearPlaceholders(); });
          phObserver.observe(host.shadowRoot, { childList: true, subtree: true });
          /* 检测 CWD 评论加载完成：监听 .cwd-loading 元素消失
             CWD 组件首次渲染会显示 .cwd-loading（自身 loading spinner），
             评论 API 返回后 loading:false → 重新渲染 → .cwd-loading 被移除。
             这是组件级别的精确信号，桌面端/移动端行为完全一致。 */
          function checkCwdLoaded(){
            var loadingEl = host.shadowRoot.querySelector('.cwd-loading');
            if(!loadingEl){
              if(window.__commentsHideLoading) window.__commentsHideLoading();
              var firstChild = host.firstElementChild;
              if(firstChild) firstChild.setAttribute('data-loaded', 'true');
              return true;
            }
            return false;
          }
          /* 立即检查一次（可能已加载完成） */
          if(!checkCwdLoaded()){
            /* 仍在加载，用 MutationObserver 监听 Shadow DOM 变化 */
            var cwdLoadObserver = new MutationObserver(function(){
              if(checkCwdLoaded()) cwdLoadObserver.disconnect();
            });
            cwdLoadObserver.observe(host.shadowRoot, { childList: true, subtree: true });
          }
        }
      }, 200);
      /* 暗黑模式切换同步：重新注入样式 + 通知 CWD 切换主题 */
      var observer = new MutationObserver(function(){
        var d = document.documentElement.getAttribute('data-theme') === 'dark';
        comments.updateConfig({ theme: d ? 'dark' : 'light' });
        var host = document.getElementById('comments-mount');
        if(host && host.shadowRoot) injectCwdStyles(host.shadowRoot, d);
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    }
    if (window.CWDComments) init();
    else {
      /* AJAX 导航时 DOMContentLoaded 已触发，改用轮询等待脚本加载 */
      var _cwdWait = setInterval(function(){
        if(window.CWDComments){ clearInterval(_cwdWait); init(); }
      }, 100);
      setTimeout(function(){ clearInterval(_cwdWait); }, 15000);
    }
  })();
</script>
<% } else { %>
<div class="comments-config-hint"><i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i><%= hintMsg %></div>
<% } %>
