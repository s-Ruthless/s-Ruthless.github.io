<%
  var posts = site.posts.sort('date', -1);
  var cats = site.categories;
%>

<div class="page-container">
  <div class="page-header">
    <h2><i class="fas fa-newspaper"></i> 全部文章 · <span class="badge badge-primary badge-sm"><%= site.posts.length %></span> 篇</h2>
  </div>
  <div class="page-body">
    <div class="flex flex-wrap gap-2 justify-center mb-6">
      <button class="filter-btn btn btn-xs btn-primary" data-cat="all">全部</button>
      <% cats.sort('name').each(function(cat) { %>
        <button class="filter-btn btn btn-xs btn-ghost" data-cat="<%= cat.name %>"><%= cat.name %> <span class="badge badge-xs"><%= cat.posts.length %></span></button>
      <% }); %>
    </div>
    <div class="wall-grid" id="posts-wall-grid">
    <% var sizes = ['card-sm','card-md','card-lg','card-md','card-sm','card-md','card-lg','card-sm','card-md','card-sm']; %>
    <% var idx = 0; %>
    <% posts.each(function(post) { %>
      <%
        var size = sizes[idx % sizes.length];
        var catName = (post.categories && post.categories.length > 0) ? post.categories.data[0].name : '';
        var fullText = strip_html(post.excerpt || post.content || '');
        var maxLen = size === 'card-sm' ? 30 : size === 'card-lg' ? 100 : 55;
        var summary = fullText.substring(0, maxLen);
        var showTags = size !== 'card-sm';
      %>
      <div class="wall-card ajax-link" data-href="<%- url_for(post.path) %>" data-cat="<%= catName %>" style="--card-bg:<%= ['#fce4ec','#e3f2fd','#fff3e0','#e8f5e9','#f3e5f5','#e0f7fa','#fff8e1','#efebe9'][idx % 8] %>;">
        <div class="card-top">
          <% if (catName) { %>
            <span class="card-cat badge badge-xs"><%= catName %></span>
          <% } %>
          <span class="card-date text-xs opacity-40"><%= date(post.date, 'YYYY-MM-DD') %></span>
        </div>
        <h3 class="card-title"><%= post.title %></h3>
        <p class="card-summary"><%= summary %><%= fullText.length > maxLen ? '...' : '' %></p>
        <% if (showTags && post.tags && post.tags.length > 0) { %>
          <div class="card-tags flex gap-1 flex-wrap mt-2">
            <% post.tags.forEach(function(tag) { %>
              <span class="badge badge-ghost badge-xs">#<%= tag.name %></span>
            <% }); %>
          </div>
        <% } %>
      </div>
      <% idx++; %>
    <% }); %>

    <% if (site.posts.length === 0) { %>
      <div class="text-center py-10 opacity-50" style="grid-column:1/-1;">还没有文章哦，快去写一篇吧～</div>
    <% } %>
    </div>
  </div>
</div>