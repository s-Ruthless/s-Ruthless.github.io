<%
  var A = (theme.cdn || '') + '/assets';
  var c = theme.comments || {};
  if (c.enable !== true) return;
  /* 评论开关：page.comment 优先；未设置时文章默认显示，自定义页面默认不显示 */
  var isPost = page.layout === 'post';
  var showComments = page.comment !== undefined ? page.comment : isPost;
  if (!showComments) return;
  var p = c.provider || 'waline';
  var giscusOk = p === 'giscus' && c.giscus && c.giscus.repo;
%>
<div class="comments-wrap" id="comments-wrap">
  <div class="comments-loading" id="comments-loading"><div class="music-loading-spinner"></div><span>评论加载中…</span></div>
  <div id="comments-mount">
    <% if (giscusOk) { %>
    <script src="https://giscus.app/client.js"
      data-repo="<%= c.giscus.repo %>"
      data-repo-id="<%= c.giscus.repoId %>"
      data-category="<%= c.giscus.category %>"
      data-category-id="<%= c.giscus.categoryId %>"
      data-mapping="<%= c.giscus.mapping || 'pathname' %>"
      data-strict="1"
      data-reactions-enabled="<%= c.giscus.reactionsEnabled !== undefined ? c.giscus.reactionsEnabled : 0 %>"
      data-emit-metadata="0"
      data-input-position="<%= c.giscus.inputPosition || 'top' %>"
      data-theme="<%= c.giscus.theme || 'preferred_color_scheme' %>"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async>
    </script>
    <% } %>
  </div>
</div>
<script>
  /* 评论系统加载完成后隐藏 loading */
  (function(){
    var loading = document.getElementById('comments-loading');
    if(!loading) return;
    var hidden = false;
    function hideLoading(){
      if(hidden) return;
      hidden = true;
      loading.style.display = 'none';
    }

    var wrap = document.getElementById('comments-wrap');
    if(wrap){
      var mo = new MutationObserver(function(){
        /* 非Giscus评论系统：检测到容器即隐藏 */
        if(wrap.querySelector('.gt-container, .tk-comment, .wl-panel')){
          hideLoading();
          mo.disconnect();
          return;
        }
        /* Giscus：iframe已插入，但不立即隐藏loading
           等iframe真正加载完成（去掉giscus-frame--loading类）再隐藏 */
        var iframe = wrap.querySelector('iframe.giscus-frame');
        if(iframe && !iframe._watched){
          iframe._watched = true;
          /* 方法1：监听iframe load事件 */
          iframe.addEventListener('load', function(){
            setTimeout(hideLoading, 200);
          });
          /* 方法2：轮询检查loading类是否被移除 */
          var checkInterval = setInterval(function(){
            if(!iframe.classList.contains('giscus-frame--loading')){
              hideLoading();
              clearInterval(checkInterval);
            }
          }, 200);
          /* 5秒后强制隐藏（防止load事件不触发） */
          setTimeout(function(){ clearInterval(checkInterval); }, 5000);
        }
      });
      mo.observe(wrap, { childList: true, subtree: true });
    }

    /* 监听 Giscus iframe 消息（备选方案） */
    window.addEventListener('message', function(e){
      if(e.origin === 'https://giscus.app'){
        setTimeout(hideLoading, 300);
      }
    });

    /* 超时兜底 */
    setTimeout(hideLoading, 15000);
  })();
</script>

<% if (giscusOk) { %>
<script>
  /* 暗黑模式同步给 Giscus（仅当 theme 为 preferred_color_scheme 时生效） */
  (function(){
    var themeMode = '<%= c.giscus.theme || 'preferred_color_scheme' %>';
    if(themeMode !== 'preferred_color_scheme') return;
    function syncTheme(){
      var iframe = document.querySelector('iframe.giscus-frame');
      if(!iframe) return;
      var dark = document.documentElement.getAttribute('data-theme') === 'dark';
      iframe.contentWindow.postMessage({
        giscus: { setConfig: { theme: dark ? 'noborder_dark' : 'noborder_light' } }
      }, 'https://giscus.app');
    }
    var observer = new MutationObserver(syncTheme);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    var checkInterval = setInterval(function(){
      if(document.querySelector('iframe.giscus-frame')){ syncTheme(); clearInterval(checkInterval); }
    }, 500);
  })();
</script>

<% } else if (p === 'waline' && c.waline && c.waline.serverURL) { %>
<link rel="stylesheet" href="<%= A %>/css/waline.css">
<script type="module">
  import { init } from '<%= A %>/js/waline.js';
  init({
    el: '#comments-mount',
    serverURL: '<%= c.waline.serverURL %>',
    dark: 'html[data-theme="dark"]',
    lang: 'zh-CN'
  });
</script>

<% } else if (p === 'twikoo' && c.twikoo && c.twikoo.envId) { %>
<script src="<%= A %>/js/twikoo.all.min.js"></script>
<script>
  (function(){
    function init(){ twikoo.init({ envId: '<%= c.twikoo.envId %>', el: '#comments-mount' }); }
    if (window.twikoo) init();
    else document.addEventListener('DOMContentLoaded', init);
  })();
</script>

<% } else if (p === 'gitalk' && c.gitalk && c.gitalk.clientID) { %>
<link rel="stylesheet" href="<%= A %>/css/gitalk.css">
<script src="<%= A %>/js/gitalk.min.js"></script>
<script>
  (function(){
    function init(){
      var gitalk = new Gitalk({
        clientID: '<%= c.gitalk.clientID %>',
        clientSecret: '<%= c.gitalk.clientSecret %>',
        repo: '<%= c.gitalk.repo %>',
        owner: '<%= c.gitalk.owner %>',
        admin: <%= JSON.stringify(c.gitalk.admin || []) %>,
        id: location.pathname,
        distractionFreeMode: false
      });
      gitalk.render('comments-mount');
    }
    if (window.Gitalk) init();
    else document.addEventListener('DOMContentLoaded', init);
  })();
</script>
<% } else { %>
<div class="comments-config-hint">评论系统已开启但配置不完整，请在主题 <code>_config.yml</code> 的 <code>comments</code> 中填写对应 provider 的字段。</div>
<% } %>
