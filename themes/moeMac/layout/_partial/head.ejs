<%
  /* cdn 配置：留空 = 使用本地 /assets/ 路径；填写后所有资源走 CDN
     例如: cdn: "https://your-cdn.com/moemac/assets"
     末尾不加 / — 统一拼接路径 */
  var A = theme.cdn || '/assets';
  var pageDesc = strip_html(page.description || page.excerpt || config.description || '');
  var ogTitle = page.title ? page.title + ' | ' + config.title : config.title;
  var ogUrl = (config.url ? config.url.replace(/\/$/,'') : '') + url_for(page.path);
  var ogImage = page.cover || theme.og_image || theme.avatar_url || '';
  var accent = theme.accent_color || '#a78bfa';
  var favicon = theme.favicon || ('data:image/svg+xml,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">' + (theme.favicon_emoji || '🌿') + '</text></svg>'));
  /* 判断当前页面类型，用于条件加载 CSS */
  var _layout = page.layout || (page.path === 'index.html' ? 'index' : 'page');
  var _isPost = _layout === 'post';
  var _isHome = _layout === 'index';
  var _isArchive = _layout === 'archive';
  var _isGallery = _layout === 'gallery';
  var _isDouban = _layout === 'douban' || _layout === 'page-douban' || (page.path || '').indexOf('douban') > -1;
%>
<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= ogTitle %></title>
  <meta name="description" content="<%= pageDesc %>">
  <% if (config.keywords || theme.keywords) { %><meta name="keywords" content="<%= config.keywords || theme.keywords %>"><% } %>
  <meta name="author" content="<%= config.author || theme.author || '' %>">
  <meta name="theme-color" content="<%= accent %>">

  <!-- favicon -->
  <link rel="icon" href="<%= favicon %>">
  <link rel="apple-touch-icon" href="<%= theme.apple_touch_icon || favicon %>">

  <%
    /* 动态资源预连接：从用户配置中提取外部域名，自动生成 preconnect + dns-prefetch
       适配所有用户 —— 只预连接用户实际配置了的外部 API/CDN 域名 */
    var _siteOrigin = (config.url || '').replace(/^\/+|\/+$/g, '');
    var _pcSet = {};
    function _addPC(url) {
      if (!url || typeof url !== 'string') return;
      var m = url.match(/^(https?:\/\/[^\/]+)/i);
      if (!m) return;
      var origin = m[1];
      if (origin === _siteOrigin) return; /* 同源不需要预连接 */
      _pcSet[origin] = true;
    }
    /* CDN 域名 */
    if (theme.cdn) _addPC(theme.cdn);
    /* 头像外部链接 */
    if (theme.avatar_type === 'image' && theme.avatar_url) _addPC(theme.avatar_url);
    /* 一言 API */
    if (theme.hitokoto && theme.hitokoto_api) _addPC(theme.hitokoto_api);
    /* 音乐 API */
    if (theme.meting_api) _addPC(theme.meting_api);
    /* 评论系统 API */
    if (theme.comments && theme.comments.enable) {
      var _cp = theme.comments.provider;
      if (_cp === 'cwd' && theme.comments.cwd && theme.comments.cwd.apiBaseUrl) _addPC(theme.comments.cwd.apiBaseUrl);
      if (_cp === 'waline' && theme.comments.waline && theme.comments.waline.serverURL) _addPC(theme.comments.waline.serverURL);
      if (_cp === 'twikoo' && theme.comments.twikoo && theme.comments.twikoo.envId) _addPC(theme.comments.twikoo.envId);
      if (_cp === 'giscus' && theme.comments.giscus && theme.comments.giscus.repo) _addPC('https://giscus.app');
    }
    /* 豆瓣页面：封面图可能使用外部 CDN */
    if (_isDouban) {
      var _db = (site.data && site.data.douban) ? site.data.douban : (theme.douban || {});
      ['books','movies'].forEach(function(k) {
        (_db[k] || []).forEach(function(it) {
          if (it.cover && !it.cover_local) _addPC(it.cover);
        });
      });
    }
    var _pcOrigins = Object.keys(_pcSet);
  %>
  <% if (_pcOrigins.length) { %>
  <!-- 资源预连接：提前建立 DNS 解析 + TCP/TLS 握手，减少外部资源加载延迟 -->
  <% _pcOrigins.forEach(function(o) { %>
  <link rel="preconnect" href="<%= o %>" crossorigin>
  <link rel="dns-prefetch" href="<%= o %>">
  <% }); %>
  <% } %>

  <!-- Open Graph -->
  <meta property="og:type" content="<%= _isPost ? 'article' : 'website' %>">
  <meta property="og:title" content="<%= page.title || config.title %>">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:url" content="<%= ogUrl %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <% if (ogImage) { %><meta property="og:image" content="<%= ogImage %>"><% } %>
  <% if (page.date) { %><meta property="article:published_time" content="<%= date(page.date, 'YYYY-MM-DDTHH:mm:ss') %>"><% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="<%= ogImage ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title" content="<%= page.title || config.title %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <% if (ogImage) { %><meta name="twitter:image" content="<%= ogImage %>"><% } %>
  <% if (theme.twitter) { %><meta name="twitter:site" content="<%= theme.twitter %>"><% } %>

  <!-- RSS 自动发现：浏览器和 RSS 阅读器通过此标签自动找到订阅地址 -->
  <% if (theme.rss && theme.rss.enable !== false) { %>
  <link rel="alternate" type="application/rss+xml" title="<%= config.title %>" href="<%= config.url %>/<%= theme.rss.path || 'atom.xml' %>">
  <% } %>

  <% var V = '?v=20260713r25'; %>

  <!-- ====== 内联关键 CSS（~1.5KB，零额外请求，防止首屏空白） ====== -->
  <style>
    /* CSS 变量 — 主题色 + 暗黑模式，供同步 CSS 文件使用 */
    :root{
      --accent-color:<%= accent %>;--accent-soft:<%= accent %>;--accent-medium:<%= accent %>;--accent-strong:<%= accent %>;
      --accent-gradient:linear-gradient(135deg,<%= accent %>,#06b6d4);
    }
    /* 基础重置 — 防止首屏空白闪烁 */
    *{margin:0;padding:0;box-sizing:border-box;}
    html{height:100%;overflow-x:hidden;}
    body{min-height:100%;overflow-x:hidden;overflow-y:scroll;font-family:"PingFang SC",-apple-system,BlinkMacSystemFont,"Helvetica Neue","Hiragino Sans GB","Microsoft YaHei",sans-serif;color:#111;background:transparent;user-select:none;-webkit-user-select:none;}
    [data-theme="dark"] body{color:#e8e8e8;}
    /* 桌面端：窗口定位前隐藏（JS 计算位置后由动画渐入）
       移动端：窗口始终可见（纵向卡片流，无需 JS 定位） */
    html.is-desktop .drag-win:not([data-pos]){opacity:0;}
    html:not(.is-desktop) .drag-win:not([data-pos]){opacity:1!important;}
    @media(max-width:768px),(max-device-width:768px){.drag-win:not([data-pos]){opacity:1!important;}}
    /* 进度条 — 在 CSS 文件加载前即可显示 */
    #nprogress-bar{position:fixed;top:0;left:0;height:3px;z-index:10000;pointer-events:none;opacity:0;width:0;background:linear-gradient(90deg,#ff6b6b,#ffa36b,#ffd56b,#6bffb8,#6bd4ff,#a06bff,#ff6bd4);background-size:200% 100%;animation:rainbow-shift 1.5s linear infinite;border-radius:0 2px 2px 0;transition:opacity 0.3s ease,width 0.2s ease;}
    #nprogress-bar.show{opacity:1;}
    @keyframes rainbow-shift{0%{background-position:0% 0}100%{background-position:200% 0}}
  </style>

  <!-- 早期主题初始化：在所有 CSS/JS 之前从 localStorage 读取暗黑模式偏好，
       避免 FOUC（内容闪烁）和 Giscus 加载时主题不匹配 -->
  <script>
    (function(){
      try { var saved = localStorage.getItem('theme'); if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark'); } catch(e){}
      /* 安全的 matchMedia 包装：部分国产浏览器 matchMedia 可能返回 null 或抛异常 */
      function mm(q){ try { return window.matchMedia ? window.matchMedia(q) : null; } catch(e){ return null; } }
      function mmMatches(q){ var m = mm(q); return m ? m.matches : false; }
      /* 移动端检测：多层策略，任一命中即为移动端 */
      var ua = navigator.userAgent || '';
      var uaMobile = /Android.*Mobile|iPhone|iPod/i.test(ua)
        || (/Android/i.test(ua) && /Honor|HWV|HUAWEI|HonorBrowser|HarmonyOS|ArkWeb/i.test(ua));
      if (!uaMobile && screen.width <= 500) uaMobile = true;
      if (!uaMobile && navigator.userAgentData && navigator.userAgentData.mobile) uaMobile = true;
      if (!uaMobile) {
        var hasTouch = (navigator.maxTouchPoints || 0) > 0 || ('ontouchstart' in window);
        var smallScreen = window.innerWidth <= 900 || (screen.width <= 900 && screen.height <= 900);
        if (hasTouch && smallScreen && !mmMatches('(hover:hover)')) uaMobile = true;
      }
      var isMobile = uaMobile || mmMatches('(max-width: 768px)') || window.innerWidth <= 768;
      if (isMobile) {
        document.documentElement.classList.add('is-mobile');
      } else {
        document.documentElement.classList.add('is-desktop');
      }
    })();
  </script>

  <!-- 卜算子访客统计 -->
  <script async src="<%= A %>/js/busuanzi.pure.mini.js"></script>

  <!-- ====== 核心 CSS 同步加载（布局+动画+JS 依赖，所有页面必需） ====== -->
  <link rel="stylesheet" href="<%= A %>/css/style.css<%= V %>">
  <link rel="stylesheet" href="<%= A %>/css/mobile.css<%= V %>">
  <link rel="stylesheet" href="<%= A %>/css/pages.css<%= V %>">
  <link rel="stylesheet" href="<%= A %>/css/icons.css<%= V %>">

  <!-- ====== 代码高亮主题 ====== -->
  <% var _ct = theme.code_theme || 'github';
     var _ctMap = { 'github':'github', 'dracula':'dracula', 'one-dark':'one-dark', 'vs':'vs' };
     var _ctFile = _ctMap[_ct] || 'github'; %>
  <link rel="stylesheet" href="<%= A %>/css/code-theme-<%= _ctFile %>.css<%= V %>">

  <!-- ====== 页面级 CSS — 当前页面同步，其他页面异步 ====== -->
  <% if (_isPost) { %>
  <link rel="stylesheet" href="<%= A %>/css/article.css<%= V %>">
  <% } else { %>
  <link rel="stylesheet" href="<%= A %>/css/article.css<%= V %>" media="print" onload="this.media='all'">
  <% } %>
  <% if (_isHome) { %>
  <link rel="stylesheet" href="<%= A %>/css/home.css<%= V %>">
  <% } else { %>
  <link rel="stylesheet" href="<%= A %>/css/home.css<%= V %>" media="print" onload="this.media='all'">
  <% } %>
  <% if (_isArchive) { %>
  <link rel="stylesheet" href="<%= A %>/css/archive.css<%= V %>">
  <% } else { %>
  <link rel="stylesheet" href="<%= A %>/css/archive.css<%= V %>" media="print" onload="this.media='all'">
  <% } %>
  <% if (_isGallery) { %>
  <link rel="stylesheet" href="<%= A %>/css/gallery.css<%= V %>">
  <% } else { %>
  <link rel="stylesheet" href="<%= A %>/css/gallery.css<%= V %>" media="print" onload="this.media='all'">
  <% } %>

  <!-- ====== 非关键 CSS 异步加载（不阻塞渲染） ====== -->
  <link rel="stylesheet" href="<%= A %>/css/components.css<%= V %>" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="<%= A %>/css/aplayer.css<%= V %>" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="<%= A %>/css/APlayer.min.css" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="<%= A %>/css/katex.min.css" media="print" onload="this.media='all'">

  <!-- LCP 图片预加载：头像和壁纸是首屏最大内容元素 -->
  <% if (theme.avatar_type === 'image' && theme.avatar_url) { %>
  <link rel="preload" href="<%= theme.avatar_url %>" as="image" fetchpriority="high">
  <% } %>
  <% if (theme.wallpaper_path) { %>
  <link rel="preload" href="<%= theme.wallpaper_path %>" as="image" fetchpriority="high">
  <% } %>

  <!-- 关键 JS 预加载：提前高优先级拉取核心脚本，缩短首屏渲染等待 -->
  <link rel="preload" href="<%= A %>/js/main.js<%= V %>" as="script">
  <link rel="preload" href="<%= A %>/js/animations.js<%= V %>" as="script">
</head>
