<%
  // hexo-generator-index 的 order_by: -date 不含 sticky 排序
  // 此处手动排序：sticky 优先，日期次之
  var posts;
  if (page.posts) {
    // 分页场景：对当前页数据重新排序
    var arr = page.posts.toArray();
    arr.sort(function(a, b) {
      var sd = (b.sticky || 0) - (a.sticky || 0);
      if (sd !== 0) return sd;
      return b.date - a.date;
    });
    posts = arr;
  } else {
    posts = site.posts.toArray().sort(function(a, b) {
      var sd = (b.sticky || 0) - (a.sticky || 0);
      if (sd !== 0) return sd;
      return b.date - a.date;
    }).slice(0, config.per_page || 10);
  }
  /* 分类图标统一使用文件夹样式 */
  var catIcon = 'fas fa-folder';
%>

<div class="page-container">
  <div class="page-body">
    <div class="page-header">
      <h2><i class="fas fa-newspaper"></i> 文章列表</h2>
    </div>
    <div class="page-content">
      <div class="list-container">
      <% posts.forEach(function(post) { %>
        <% var coverImg = post.cover || post.thumbnail || ''; %>
        <div class="post-list-item ajax-link<% if (post.sticky) { %> post-sticky<% } %>" data-href="<%- url_for(post.path) %>">
          <% if (coverImg) { %>
<div class="post-list-cover">
<img src="<%= coverImg %>" alt="<%= post.title %>" loading="lazy" onload="this.classList.add('loaded');this.parentElement.classList.add('loaded');" onerror="this.parentElement.style.display='none'">
</div>
          <% } %>
          <% if (post.sticky) { %>
            <span class="sticky-badge"><i class="fas fa-thumbtack"></i> 置顶</span>
          <% } %>
          <h3 class="ajax-link" data-href="<%- url_for(post.path) %>"><%= post.title %></h3>
          <div class="post-meta">
            <i class="fas fa-calendar-days"></i>
            <span><%= date(post.date, 'YYYY-MM-DD') %></span>
            <% if (post.categories && post.categories.length > 0) { %>
              <span>·</span>
              <% post.categories.forEach(function(cat, i) { %>
                <i class="<%= catIcon %>"></i>
                <a class="ajax-link" data-href="<%- url_for(cat.path) %>"><%= cat.name %></a><%= i < post.categories.length - 1 ? ', ' : '' %>
              <% }); %>
            <% } %>
          </div>
          <% if (post.excerpt || post.content) { %>
            <p class="post-excerpt"><%- strip_html(post.excerpt || post.content || '').substring(0, 120) %></p>
          <% } %>
          <% if (post.tags && post.tags.length > 0) { %>
            <div class="post-list-tags">
              <% post.tags.forEach(function(tag) { %>
                <a class="post-list-tag ajax-link" data-href="<%- url_for(tag.path) %>">
                  <i class="fas fa-hashtag"></i><%= tag.name %>
                </a>
              <% }); %>
            </div>
          <% } %>
        </div>
      <% }); %>
      </div>

      <% if (site.posts.length === 0) { %>
        <div class="list-empty">还没有文章哦，快去写一篇吧～</div>
      <% } %>

      <% if (typeof page.total !== 'undefined' && page.total > 1) { %>
        <div class="list-pagination">
          <% if (page.prev) { %>
            <a class="page-btn ajax-link" data-href="<%- url_for(page.prev_link) %>"><i class="fas fa-chevron-left"></i> 上一页</a>
          <% } %>
          <span class="page-info"><%= page.current %> / <%= page.total %></span>
          <% if (page.next) { %>
            <a class="page-btn ajax-link" data-href="<%- url_for(page.next_link) %>">下一页 <i class="fas fa-chevron-right"></i></a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
