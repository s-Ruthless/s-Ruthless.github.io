<%
  /* 从 page.raw（原始 Markdown）中解析相册数据
     Markdown 语法：![标题](缩略图URL)
     下一行 large: 大图URL（可选，不写则用缩略图） */
  var galleryData = [];
  var rawContent = page.raw || '';
  var lines = rawContent.split('\n');
  var inComment = false;
  var inFrontMatter = false;
  for (var i = 0; i < lines.length; i++) {
    var line = lines[i].trim();
    /* 跳过 front-matter */
    if (line === '---') { inFrontMatter = !inFrontMatter; continue; }
    if (inFrontMatter) continue;
    /* 跳过多行 HTML 注释 */
    if (line.startsWith('<!--')) { inComment = true; }
    if (inComment) {
      if (line.indexOf('-->') !== -1) inComment = false;
      continue;
    }
    /* 跳过标题行 */
    if (line.startsWith('#')) continue;
    /* 检查 large: 行 — 更新最后一张图片的大图 URL */
    var largeMatch = line.match(/^large:\s*(\S+)/);
    if (largeMatch) {
      if (galleryData.length > 0) {
        galleryData[galleryData.length - 1].large = largeMatch[1];
      }
      continue;
    }
    /* 检查图片行 ![alt](url) */
    var imgMatch = line.match(/^!\[([^\]]*)\]\(([^)]+)\)/);
    if (imgMatch) {
      galleryData.push({
        title: imgMatch[1] || '',
        thumb: imgMatch[2],
        large: imgMatch[2]
      });
    }
  }
%>
<%
  var _icon = 'fas fa-images';
  var _path = (page.path || '').replace(/\/index\.html$/, '').replace(/^\/|\/$/g, '');
  (theme.dock || []).forEach(function(item){
    if ((item.page || '').replace(/^\/|\/$/g, '') === _path) _icon = item.icon;
  });
%>
<div class="page-container">
  <div class="page-body gallery-page">
    <div class="page-header">
      <h2><i class="<%- _icon %>"></i> 相册</h2>
      <p class="archive-subtitle">用镜头记录生活中的美好瞬间</p>
    </div>
    <div class="page-content">
    <div class="gallery-masonry" id="galleryMasonry">
      <!-- 图片由 JS 动态加载 -->
    </div>
    <div class="gallery-loader" id="galleryLoader">
      <i class="fas fa-circle-notch fa-spin"></i>
      <span>加载中…</span>
    </div>
    <div class="gallery-end" id="galleryEnd" style="display:none;">
      <span>没有更多了 ~</span>
    </div>
    </div>
  </div>
</div>

<!-- 图片灯箱 -->
<div class="gallery-lightbox" id="galleryLightbox">
  <div class="lightbox-mask"></div>
  <div class="lightbox-close" id="lightboxClose"><i class="fas fa-xmark"></i></div>
  <div class="lightbox-content">
    <img id="lightboxImg" src="" alt="">
  </div>
  <div class="lightbox-prev" id="lightboxPrev"><i class="fas fa-chevron-left"></i></div>
  <div class="lightbox-next" id="lightboxNext"><i class="fas fa-chevron-right"></i></div>
</div>

<script>
  /* 相册数据 — 由 index.md 中的 Markdown 图片语法生成 */
  var GALLERY_DATA = <%- JSON.stringify(galleryData) %>;
</script>
